{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/plugins.php",
	"login": true,
	"steps": [
		{
			"step": "activatePlugin",
			"pluginName": "FOSSE",
			"pluginPath": "/wordpress/wp-content/plugins/fosse/fosse.php"
		},
		{
			"step": "mkdir",
			"path": "/wordpress/wp-content/mu-plugins"
		},
		{
			"step": "cp",
			"fromPath": "/wordpress/wp-content/plugins/fosse/tests/e2e/mu-plugins/fosse-bsky-capture.php",
			"toPath": "/wordpress/wp-content/mu-plugins/fosse-bsky-capture.php"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"fosse_object_type": "note",
				"activitypub_reader_ui": "1"
			}
		}
	]
}
