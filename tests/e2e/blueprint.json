{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/plugins.php",
	"login": true,
	"steps": [
		{
			"step": "defineWpConfigConsts",
			"consts": {
				"WP_DEBUG": true,
				"WP_DEBUG_LOG": true,
				"WP_DEBUG_DISPLAY": false
			}
		},
		{
			"step": "activatePlugin",
			"pluginName": "FOSSE",
			"pluginPath": "/wordpress/wp-content/plugins/fosse/fosse.php"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"fosse_object_type": "note"
			}
		}
	]
}
