{
	"name": "automattic/fosse",
	"description": "Social Web for WordPress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"automattic/wordbless": "dev-trunk",
		"phpunit/phpunit": "^9.6 || ^11.0",
		"yoast/phpunit-polyfills": "^4.0"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"autoload": {
		"classmap": [
			"src/"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Automattic\\Fosse\\Tests\\": "tests/php/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"roots/wordpress-core-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"post-install-cmd": [
			"WorDBless\\Composer\\InstallDropin::copy"
		],
		"post-update-cmd": [
			"WorDBless\\Composer\\InstallDropin::copy"
		],
		"test-php": [
			"phpunit --colors=always"
		],
		"lint-php": [
			"tools/vendor/bin/phpcs"
		],
		"fix-php": [
			"tools/vendor/bin/phpcbf"
		]
	}
}
